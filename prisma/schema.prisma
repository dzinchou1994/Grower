generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum DiaryEnvironment {
  INDOOR
  OUTDOOR
  GREENHOUSE
}

/** Active grow vs finished run — used for explore filters. */
enum DiaryGrowPhase {
  GROWING
  HARVESTED
}

enum DiaryFlowerType {
  AUTOFLOWER
  PHOTOPERIOD
}

enum DiaryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DiaryGerminationMethod {
  PAPER_TOWEL
  GLASS_OF_WATER
  ROCKWOOL_CUBE
  PEAT_PELLET
  DIRECTLY_IN_SUBSTRATE
  OTHER
}

enum DiaryWateringType {
  MANUAL
  DRIP
  HYDROPONICS
  AEROPONICS
}

enum DiarySubstrateMedium {
  SOIL
  PERLITE
  VERMICULITE
  EXPANDED_CLAY
  COCO
  PEAT
  COCO_COIR
  MINERAL_WOOL
  OTHER
}

enum ReportTargetType {
  DIARY
  DIARY_WEEK
  THREAD
  COMMENT
  USER
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

enum AuditTargetType {
  USER
  DIARY
  DIARY_WEEK
  THREAD
  COMMENT
  REPORT
  SYSTEM
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  HIDE
  UNHIDE
  LOCK
  UNLOCK
  PIN
  UNPIN
  SUSPEND
  UNSUSPEND
  ROLE_CHANGE
  REPORT_REVIEW
}

enum SeoPage {
  HOME
  FORUM
  DIARIES
  CANNAPEDIA
}

enum FeedbackStatus {
  NEW
  REVIEWED
  PLANNED
  CLOSED
}

enum NewsScope {
  GEORGIA
  WORLD
}

enum NewsSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String          @unique
  passwordHash  String?
  image         String?
  bio           String?
  role          UserRole        @default(USER)
  isSuspended   Boolean         @default(false)
  suspendedUntil DateTime?
  suspensionReason String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  diaries       Diary[]
  forumThreads  ForumThread[]
  forumComments ForumComment[]
  reports       Report[]        @relation("ReportAuthor")
  reviewed      Report[]        @relation("ReportReviewer")
  auditLogs     AuditLog[]      @relation("AuditActor")
  following     Follow[]        @relation("Following")
  followers     Follow[]        @relation("Followers")
  likes         Like[]
  votes         Vote[]
  feedbacks     Feedback[]
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageRecipient")
  createdNews      NewsArticle[]      @relation("NewsCreator")
  reviewedNews     NewsArticle[]      @relation("NewsReviewer")
  newsSubmissions  NewsSubmission[]   @relation("NewsSubmitter")
  reviewedSubmissions NewsSubmission[] @relation("NewsSubmissionReviewer")
  diaryWeekComments DiaryWeekComment[]
  diaryComments     DiaryComment[]
}

model Diary {
  id                  String                 @id @default(cuid())
  slug                String                 @unique
  title               String
  /** Legacy primary strain label; kept in sync with first `strains` entry when present. */
  strain              String
  environment         DiaryEnvironment
  /** Veg/flower run vs jars / done. */
  growPhase           DiaryGrowPhase         @default(GROWING)
  /** Autoflower vs photoperiod genetics. */
  flowerType          DiaryFlowerType        @default(PHOTOPERIOD)
  germinationMethod   DiaryGerminationMethod @default(OTHER)
  watering            DiaryWateringType      @default(MANUAL)
  medium              DiarySubstrateMedium   @default(SOIL)
  description         String?
  coverImageUrl       String?
  /** Optional grow setup: tents, lights, ventilation, substrates, etc. (JSON). */
  setup               Json?
  status              DiaryStatus            @default(PUBLISHED)
  isFeatured          Boolean                @default(false)
  isHidden            Boolean                @default(false)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  authorId            String
  author              User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  weeks               DiaryWeek[]
  strains             DiaryStrain[]
  diaryComments       DiaryComment[]

  @@index([authorId, createdAt])
  @@index([status, isHidden, updatedAt])
  @@index([germinationMethod])
  @@index([watering])
  @@index([medium])
  @@index([growPhase])
  @@index([flowerType])
}

model DiaryStrain {
  id        String @id @default(cuid())
  diaryId   String
  name      String
  breeder   String?
  sortOrder Int    @default(0)
  diary     Diary  @relation(fields: [diaryId], references: [id], onDelete: Cascade)

  @@index([diaryId, sortOrder])
}

model DiaryWeek {
  id          String           @id @default(cuid())
  diaryId     String
  weekNumber  Int
  title       String?
  description String
  isHidden     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  diary       Diary            @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  images      DiaryWeekImage[]
  likes       Like[]
  reports     Report[]
  comments    DiaryWeekComment[]

  @@unique([diaryId, weekNumber])
  @@index([diaryId, createdAt])
}

model DiaryWeekImage {
  id          String    @id @default(cuid())
  diaryWeekId String
  imageUrl    String
  sortOrder   Int       @default(0)
  diaryWeek   DiaryWeek @relation(fields: [diaryWeekId], references: [id], onDelete: Cascade)
}

model DiaryWeekComment {
  id          String    @id @default(cuid())
  diaryWeekId String
  authorId    String
  body        String
  isHidden    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  diaryWeek   DiaryWeek @relation(fields: [diaryWeekId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([diaryWeekId, createdAt])
}

/** Comments on the diary as a whole (not tied to a specific week). */
model DiaryComment {
  id        String   @id @default(cuid())
  diaryId   String
  authorId  String
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  diary     Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([diaryId, createdAt])
}

model ForumTopic {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  threads     ForumThread[]
}

model CannapediaCategory {
  id        String             @id @default(cuid())
  slug      String             @unique
  nameKa    String
  nameEn    String
  nameRu    String
  icon      String             @default("🌿")
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  articles  CannapediaArticle[]

  @@index([sortOrder])
}

model CannapediaArticle {
  id          String             @id @default(cuid())
  slug        String             @unique
  categoryId  String
  readMinutes Int                @default(5)
  titleKa     String
  titleEn     String
  titleRu     String
  excerptKa   String
  excerptEn   String
  excerptRu   String
  contentKa   String
  contentEn   String
  contentRu   String
  isPublished Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  category    CannapediaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, createdAt])
}

model ForumThread {
  id         String         @id @default(cuid())
  slug       String         @unique
  topicId    String
  authorId   String
  title      String
  body       String
  isPinned   Boolean        @default(false)
  isLocked   Boolean        @default(false)
  isHidden   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  topic      ForumTopic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author     User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments   ForumComment[]
  likes      Like[]
  votes      Vote[]
  reports    Report[]

  @@index([topicId, createdAt])
}

model ForumComment {
  id        String      @id @default(cuid())
  threadId   String
  authorId   String
  body       String
  isHidden   Boolean     @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  thread     ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes      Like[]
  votes      Vote[]
  reports    Report[]

  @@index([threadId, createdAt])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Like {
  id         String        @id @default(cuid())
  userId     String
  diaryWeekId String?
  threadId   String?
  commentId  String?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  diaryWeek  DiaryWeek?    @relation(fields: [diaryWeekId], references: [id], onDelete: Cascade)
  thread     ForumThread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment    ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Vote {
  id        String       @id @default(cuid())
  userId    String
  value     Int          // 1 = upvote, -1 = downvote
  threadId  String?
  commentId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread    ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment   ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@unique([userId, commentId])
  @@index([threadId])
  @@index([commentId])
}

model Report {
  id          String           @id @default(cuid())
  reporterId  String
  reviewerId  String?
  targetType  ReportTargetType
  targetId    String
  reason      String
  status      ReportStatus     @default(OPEN)
  reviewerNote String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  reporter    User             @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer    User?            @relation("ReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  diaryWeekId String?
  threadId    String?
  commentId   String?
  diaryWeek   DiaryWeek?       @relation(fields: [diaryWeekId], references: [id], onDelete: Cascade)
  thread      ForumThread?     @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment     ForumComment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model AuditLog {
  id          String          @id @default(cuid())
  actorId     String?
  actor       User?           @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   UserRole?
  action      AuditActionType
  targetType  AuditTargetType
  targetId    String
  reason      String?
  beforeJson  String?
  afterJson   String?
  createdAt   DateTime        @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

model SeoSetting {
  id              String   @id @default(cuid())
  page            SeoPage
  locale          String
  metaTitle       String
  metaDescription String
  ogTitle         String?
  ogDescription   String?
  keywords        String?
  noIndex         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([page, locale])
  @@index([page])
  @@index([locale])
}

model Feedback {
  id                String         @id @default(cuid())
  userId            String?
  name              String?
  siteRating        Int
  contentRating     Int
  performanceRating Int
  whatToAdd         String
  whatToImprove     String?
  status            FeedbackStatus @default(NEW)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  body        String
  isHidden    Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@index([isHidden, createdAt])
}

model NewsArticle {
  id           String    @id @default(cuid())
  slug         String    @unique
  scope        NewsScope
  imageUrl     String?
  sourceName   String?
  sourceUrl    String?
  titleKa      String
  titleEn      String
  titleRu      String
  excerptKa    String
  excerptEn    String
  excerptRu    String
  bodyKa       String
  bodyEn       String
  bodyRu       String
  isPublished  Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  String?
  reviewedById String?
  createdBy    User?     @relation("NewsCreator", fields: [createdById], references: [id], onDelete: SetNull)
  reviewedBy   User?     @relation("NewsReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  submissionId String?   @unique
  submission   NewsSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([scope, createdAt])
  @@index([isPublished, createdAt])
}

model NewsSubmission {
  id          String               @id @default(cuid())
  title       String
  body        String
  imageUrl    String?
  sourceName  String?
  sourceUrl   String?
  scope       NewsScope
  status      NewsSubmissionStatus @default(PENDING)
  adminNote   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  submitterId String?
  reviewedById String?
  submitter   User?                @relation("NewsSubmitter", fields: [submitterId], references: [id], onDelete: SetNull)
  reviewedBy  User?                @relation("NewsSubmissionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  article     NewsArticle?

  @@index([status, createdAt])
}
