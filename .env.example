# Local: Postgres. Vercel/Neon: set DATABASE_URL in Project → Environment Variables.
# Schema updates: run `npm run db:migrate:deploy` locally or in CI against that DB (not during Vercel build —
# existing DBs may need Prisma "baselining" first; see https://pris.ly/d/migrate-baseline if migrate deploy errors with P3005).
# If production logs show P2023 / COCO_COIR enum: see prisma/NEON-fix-COCO-COIR.txt and run that migration on Neon.
# Neon: if `migrate deploy` errors with P1002 advisory lock, run migrate using Neon "Direct" host (not `-pooler`) — see that file.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/geocannabis?schema=public"
NEXTAUTH_SECRET="replace-this-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Diary week photo uploads on Vercel (optional locally — dev falls back to public/uploads)
BLOB_READ_WRITE_TOKEN=""
